# Copy this file to config.env and fill in your values
# Then source it before deploying: source config.env

# AWS Configuration
export AWS_REGION=us-east-1
export PROJECT_NAME=new-hire-tac

# Certificate ARNs
# ACM certificate for tac.it.proof.com
export SSL_CERT_ARN=arn:aws:acm:us-east-1:913807247959:certificate/5820aca5-079a-4a3f-aee2-26a2b83ad0f6
export CA_CERT_ARN=  # Will configure mTLS client validation manually in ALB console

# Iru API Configuration
export IRU_API_URL=https://proof.api.kandji.io
# IRU_API_TOKEN will be stored in AWS Secrets Manager

# Okta Configuration
export OKTA_DOMAIN=proof.okta.com
export OKTA_CLIENT_ID=0oa12qgvzx92ZbuKt698
export OKTA_WORKFLOW_URL=https://proof.okta.com/api/fga/flow/your-flow-id/invoke

# VPC Configuration (using specific VPC)
export VPC_ID=vpc-0e0009793d14d0b5c
# export SUBNET_IDS="subnet-12345678 subnet-87654321"  # Will auto-detect from VPC

# Domain Configuration
# ALB will be accessible at: tac.it.proof.com (using *.it.proof.com wildcard cert)